# Supabase (Project Settings → API). Optional: pipeline runs without persistence if unset.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=your_anon_or_service_role_key

# Shiny frontend → FastAPI base URL (no trailing slash)
PCOSENSE_API_URL=http://127.0.0.1:8000

# Comma-separated browser origins for CORS (FastAPI)
# CORS_ORIGINS=http://127.0.0.1:3838,http://localhost:3838
